{
  "info": {
    "name": "WorkNest - Employee Management System",
    "_postman_id": "worknest-ems-collection",
    "description": "Postman collection for WorkNest Employee Management System APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"test12345\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/accounts/register/",
              "host": ["{{base_url}}"],
              "path": ["accounts", "register", ""]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"test12345\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/accounts/login/",
              "host": ["{{base_url}}"],
              "path": ["accounts", "login", ""]
            }
          }
        },
        {
          "name": "Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/accounts/profile/",
              "host": ["{{base_url}}"],
              "path": ["accounts", "profile", ""]
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"old_password\": \"test12345\",\n  \"new_password\": \"newpass12345\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/accounts/change-password/",
              "host": ["{{base_url}}"],
              "path": ["accounts", "change-password", ""]
            }
          }
        }
      ]
    },
    {
      "name": "Forms",
      "item": [
        {
          "name": "Create Form",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Employee Basic Form\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/forms/",
              "host": ["{{base_url}}"],
              "path": ["forms", ""]
            }
          }
        },
        {
          "name": "List Forms",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/forms/",
              "host": ["{{base_url}}"],
              "path": ["forms", ""]
            }
          }
        },
        {
          "name": "Add Field to Form",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label\": \"First Name\",\n  \"field_type\": \"text\",\n  \"required\": true,\n  \"order\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/forms/1/fields/",
              "host": ["{{base_url}}"],
              "path": ["forms", "1", "fields", ""]
            }
          }
        },
        {
          "name": "Reorder Fields",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fields\": [\n    {\"id\": 1, \"order\": 1},\n    {\"id\": 2, \"order\": 2}\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/forms/1/fields/reorder/",
              "host": ["{{base_url}}"],
              "path": ["forms", "1", "fields", "reorder", ""]
            }
          }
        }
      ]
    },
    {
